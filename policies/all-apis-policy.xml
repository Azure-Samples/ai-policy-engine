        -->

        <!-- Lookup backendId using a Named Value containing JSON -->
        <set-variable name="tenantBackendMapJson" value="{{tenant-backend-map}}" />
        
        <set-variable name="targetBackendId" value='@{
            var map = Newtonsoft.Json.Linq.JObject.Parse((string)context.Variables["tenantBackendMapJson"]);
            string tenant = (string)context.Variables["tenantId"];

            if (!string.IsNullOrEmpty(tenant) && map.ContainsKey(tenant))
            {
                return (string)map[tenant];
            }
            // tenant not found in map — reject request
            return "";
        }' />

        <!-- Route to backend or reject -->
        <choose>
            <when condition='@(context.Request.OriginalUrl.Path.StartsWith("/archtigeropenai2/openai", StringComparison.OrdinalIgnoreCase))'>
                <!-- Foundry / service-principal path: route directly to the archtigeropenai2 backend -->
                <set-backend-service backend-id="archtigeropenai2-ai-endpoint" />
                <!-- Strip /archTigerOpenAI2/openai prefix; backend already includes /openai in its base URL -->
                <rewrite-uri template='@{
                    string path = context.Request.OriginalUrl.Path;
                    int idx = path.IndexOf("/openai", StringComparison.OrdinalIgnoreCase);
                    return idx >= 0 ? path.Substring(idx + "/openai".Length) : "/";
                }' copy-unmatched-params="true" />
            </when>
            <when condition='@(context.Request.OriginalUrl.Path.StartsWith("/openai-llm", StringComparison.OrdinalIgnoreCase))'>
                <!-- Foundry / service-principal path: route to the archtigeropenai2llm backend -->
                <set-backend-service backend-id="archtigeropenai2llm-ai-endpoint" />
                <!-- Strip /openai-llm prefix; backend already includes /openai in its base URL -->
                <rewrite-uri template='@{
                    string path = context.Request.OriginalUrl.Path;
                    int idx = path.IndexOf("/openai", StringComparison.OrdinalIgnoreCase);
                    return idx >= 0 ? path.Substring(idx + "/openai".Length) : "/";
                }' copy-unmatched-params="true" />
            </when>
            <when condition='@(!string.IsNullOrEmpty((string)context.Variables["targetBackendId"]))'>
                <set-backend-service backend-id='@((string)context.Variables["targetBackendId"])' />
                <!-- Rewrite the uri based on the backend + API URL suffix (https://tiger.dazlmkengdev02.ienergycloud.solutions/services/microservice-holesection) -->
                <rewrite-uri template="@{ return context.Request.OriginalUrl.Path; }" copy-unmatched-params="true" />
            </when>
        <otherwise>
            <return-response>
            <set-status code="403" reason="Unknown tenant" />
            <set-header name="Content-Type" exists-action="override">
                <value>application/json</value>
            </set-header>
            <set-body>{"error":"Unknown tenant"}</set-body>
            </return-response>
        </otherwise>
        </choose>

    </inbound>

    <backend>
        <forward-request />
    </backend>

    <outbound>
        <set-variable name="logStartTime" value="@(DateTime.UtcNow.Ticks.ToString())" />

        <!-- Extract token usage from the LLM response body into variables.            -->
        <!-- Non-AI requests (empty deploymentId) get zero counts and empty model.     -->
        <!-- These variables are used by both the Chargeback API log and emit-metrics. -->
        <set-variable name="aiModel" value='@{
            string deploymentId = (string)context.Variables["deploymentId"];
            if (string.IsNullOrEmpty(deploymentId)) { return ""; }
            try {
                var resp = JObject.Parse(context.Response.Body.As<string>(preserveContent: true) ?? "{}");
                return resp["model"]?.ToString() ?? "";
            } catch { return ""; }
        }' />
        <set-variable name="promptTokens" value='@{
            string deploymentId = (string)context.Variables["deploymentId"];
            if (string.IsNullOrEmpty(deploymentId)) { return 0; }
            try {
                var resp = JObject.Parse(context.Response.Body.As<string>(preserveContent: true) ?? "{}");
                return (int)(resp["usage"]?["prompt_tokens"] ?? 0);
            } catch { return 0; }
        }' />
        <set-variable name="completionTokens" value='@{
            string deploymentId = (string)context.Variables["deploymentId"];
            if (string.IsNullOrEmpty(deploymentId)) { return 0; }
            try {
                var resp = JObject.Parse(context.Response.Body.As<string>(preserveContent: true) ?? "{}");
                return (int)(resp["usage"]?["completion_tokens"] ?? 0);
            } catch { return 0; }
        }' />
        <set-variable name="totalTokens" value='@{
            string deploymentId = (string)context.Variables["deploymentId"];
            if (string.IsNullOrEmpty(deploymentId)) { return 0; }
            try {
                var resp = JObject.Parse(context.Response.Body.As<string>(preserveContent: true) ?? "{}");
                return (int)(resp["usage"]?["total_tokens"] ?? 0);
            } catch { return 0; }
        }' />

        <!-- Fire-and-forget usage log — route to /api/log for AI requests, /api/log-rest for non-AI -->
        <choose>
            <when condition='@(!string.IsNullOrEmpty((string)context.Variables["deploymentId"]))'>
                <!-- AI request: send token usage to /api/log -->
                <send-request mode="new"
                              response-variable-name="logResponse"
                              timeout="3"
                              ignore-error="true">
                    <set-url>@($"{{AIPolicyApiBaseUrl}}/api/log")</set-url>
                    <set-method>POST</set-method>
                    <set-header name="Content-Type" exists-action="override">
                        <value>application/json</value>
                    </set-header>
                    <set-header name="Authorization" exists-action="override">
                        <value>@("Bearer " + (string)context.Variables["chargebackApiToken"])</value>
                    </set-header>
                    <set-body>@{
                        return new JObject(
                            new JProperty("clientAppId",  (string)context.Variables["clientAppId"]),
                            new JProperty("tenantId",     (string)context.Variables["tenantId"]),
                            new JProperty("deploymentId", (string)context.Variables["deploymentId"]),
                            new JProperty("responseBody", new JObject(
                                new JProperty("model", (string)context.Variables["aiModel"]),
                                new JProperty("usage", new JObject(
                                    new JProperty("prompt_tokens",     (int)context.Variables["promptTokens"]),
                                    new JProperty("completion_tokens", (int)context.Variables["completionTokens"]),
                                    new JProperty("total_tokens",      (int)context.Variables["totalTokens"])
                                ))
                            ))
                        ).ToString();
                    }</set-body>
                </send-request>
            </when>
            <otherwise>
                <!-- Non-AI request: send request metadata to /api/log-rest -->
                <send-request mode="new"
                              response-variable-name="logResponse"
                              timeout="3"
                              ignore-error="true">
                    <set-url>@($"{{AIPolicyApiBaseUrl}}/api/log-rest")</set-url>
                    <set-method>POST</set-method>
                    <set-header name="Content-Type" exists-action="override">
                        <value>application/json</value>
                    </set-header>
                    <set-header name="Authorization" exists-action="override">
                        <value>@("Bearer " + (string)context.Variables["chargebackApiToken"])</value>
                    </set-header>
                    <set-body>@{
                        var payload = new JObject();
                        payload.Add(new JProperty("tenantId",     (string)context.Variables["tenantId"]));
                        payload.Add(new JProperty("clientAppId",  (string)context.Variables["clientAppId"]));
                        payload.Add(new JProperty("customerKey",  (string)context.Variables["clientAppId"] + ":" + (string)context.Variables["tenantId"]));
                        payload.Add(new JProperty("apiId",        context.Api.Id));
                        payload.Add(new JProperty("operationId",  context.Operation.Id));
                        payload.Add(new JProperty("requestPath",  context.Request.OriginalUrl.Path));
                        payload.Add(new JProperty("statusCode",   context.Response.StatusCode));
                        payload.Add(new JProperty("latencyMs",    (long)((DateTime.UtcNow.Ticks - long.Parse((string)context.Variables["requestStartTime"])) / 10000)));
                        payload.Add(new JProperty("correlationId", context.RequestId.ToString()));
                        return payload.ToString();
                    }</set-body>
                </send-request>
            </otherwise>
        </choose>

        <emit-metric name="chargebackApiResponseTimeMs"
                    value='@((double)((DateTime.UtcNow.Ticks - long.Parse((string)context.Variables["logStartTime"])) / 10000.0))'
                    namespace="apim-metrics">
            <dimension name="API ID" />
            <dimension name="Operation ID" />
            <dimension name="clientAppId" value="@((string)context.Variables["clientAppId"])" />
            <dimension name="tenantId" value="@((string)context.Variables["tenantId"])" />
            <dimension name="operation" value="log" />
            <dimension name="statusCode" value="@(context.Variables.ContainsKey("logResponse") ? ((IResponse)context.Variables["logResponse"]).StatusCode.ToString() : "0")" />
        </emit-metric>

        <!-- LLM token usage metrics (zero for non-AI requests) -->
        <choose>
            <when condition='@(!string.IsNullOrEmpty((string)context.Variables["deploymentId"]))'>
                <emit-metric name="llmPromptTokens" value='@((double)(int)context.Variables["promptTokens"])' namespace="apim-metrics">
                    <dimension name="API ID" />
                    <dimension name="Operation ID" />
                    <dimension name="clientAppId" value="@((string)context.Variables["clientAppId"])" />
                    <dimension name="tenantId" value="@((string)context.Variables["tenantId"])" />
                    <dimension name="deploymentId" value="@((string)context.Variables["deploymentId"])" />
                    <dimension name="model" value="@((string)context.Variables["aiModel"])" />
                </emit-metric>
                <emit-metric name="llmCompletionTokens" value='@((double)(int)context.Variables["completionTokens"])' namespace="apim-metrics">
                    <dimension name="API ID" />
                    <dimension name="Operation ID" />
                    <dimension name="clientAppId" value="@((string)context.Variables["clientAppId"])" />
                    <dimension name="tenantId" value="@((string)context.Variables["tenantId"])" />
                    <dimension name="deploymentId" value="@((string)context.Variables["deploymentId"])" />
                    <dimension name="model" value="@((string)context.Variables["aiModel"])" />
                </emit-metric>
                <emit-metric name="llmTotalTokens" value='@((double)(int)context.Variables["totalTokens"])' namespace="apim-metrics">
                    <dimension name="API ID" />
                    <dimension name="Operation ID" />
                    <dimension name="clientAppId" value="@((string)context.Variables["clientAppId"])" />
                    <dimension name="tenantId" value="@((string)context.Variables["tenantId"])" />
                    <dimension name="deploymentId" value="@((string)context.Variables["deploymentId"])" />
                    <dimension name="model" value="@((string)context.Variables["aiModel"])" />
                </emit-metric>
            </when>
        </choose>

        <!-- Custom metrics -->
        <set-variable name="responseTimeMs" value='@(
            context.Variables.ContainsKey("requestStartTime") 
            ? (double)((DateTime.UtcNow.Ticks - long.Parse((string)context.Variables["requestStartTime"])) / 10000.0) 
            : 0.0
        )' />
        <emit-metric name="ResponseTimeMs" value='@( (double)context.Variables["responseTimeMs"])' namespace="apim-metrics"> 
            <dimension name="API ID" /> 
            <dimension name="Operation ID" /> 
            <dimension name="Product ID" /> 
            <dimension name="tenantId" value="@((string)context.Variables["tenantId"])" /> 
            <dimension name="clientAppId" value="@((string)context.Variables["clientAppId"])" /> 
            <dimension name="userEmail" value="@((string)context.Variables["userEmail"])" /> 
            <dimension name="statusCode" value="@(((int)context.Response.StatusCode).ToString())" />
            <dimension name="cacheHit" value="@(context.Variables.ContainsKey("isCacheHit") && (bool)context.Variables["isCacheHit"] ? "true" : "false")" />
        </emit-metric>
        <choose>
            <when condition="@(context.Response.StatusCode >= 400)">
                <emit-metric name="errorCount" value="1" namespace="apim-metrics">
                <dimension name="API ID" />
                <dimension name="Operation ID" />
                <dimension name="Product ID" />
                <dimension name="tenantId" value="@((string)context.Variables["tenantId"])" />
                <dimension name="clientAppId" value="@((string)context.Variables["clientAppId"])" />
                <dimension name="userEmail" value="@((string)context.Variables["userEmail"])" />
                <dimension name="statusCode" value="@(((int)context.Response.StatusCode).ToString())" />
                </emit-metric>
            </when>
        </choose>
        <emit-metric name="responseSize" value='@((double)(context.Response.Body.As<string>(preserveContent: true)?.Length ?? 0))' namespace="apim-metrics">
            <dimension name="API ID" />
            <dimension name="Operation ID" />
            <dimension name="Product ID" />
            <dimension name="tenantId" value="@((string)context.Variables["tenantId"])" />
            <dimension name="clientAppId" value="@((string)context.Variables["clientAppId"])" />
            <dimension name="userEmail" value="@((string)context.Variables["userEmail"])" />
            <dimension name="statusCode" value="@(((int)context.Response.StatusCode).ToString())" />
        </emit-metric>
        <!-- Return cache key in response header for debugging -->
        <choose>
            <when condition='@(context.Variables.ContainsKey("cacheKey"))'>
                <set-header name="X-Cache-Key" exists-action="override">
                    <value>@((string)context.Variables["cacheKey"])</value>
                </set-header>
            </when>
        </choose>
        <!-- Store successful GET/POST responses in external cache (skip if this response was itself a cache hit) -->
        <choose>
            <when condition='@(
                (context.Request.Method == "GET" || context.Request.Method == "POST")
                && context.Response.StatusCode == 200
                && context.Variables.ContainsKey("cacheKey")
                && !(context.Variables.ContainsKey("isCacheHit") && (bool)context.Variables["isCacheHit"]))'>
                <cache-store-value key='@((string)context.Variables["cacheKey"])' value='@(context.Response.Body.As<string>(preserveContent: true))' duration="300" caching-type="external" />
                <trace source="cache-debug" severity="information">
                    @{ return $"CACHE STORE key={context.Variables["cacheKey"]}"; }
                </trace>
            </when>
        </choose>
        <trace source="response-trace" severity="information">
            @{
                return new JObject(
                    new JProperty("event", "response-sent"),
                    new JProperty("tenantId", (string)context.Variables["tenantId"]),
                    new JProperty("clientAppId", (string)context.Variables["clientAppId"]),
                    new JProperty("userEmail", (string)context.Variables["userEmail"]),
                    new JProperty("apiId", (string)context.Api.Id),
                    new JProperty("operationId", (string)context.Operation.Id),
                    new JProperty("productId", context.Product?.Id ?? "none"),
                    new JProperty("responseTimeMs", (double)context.Variables["responseTimeMs"]),
                    new JProperty("statusCode", context.Response.StatusCode),
                    new JProperty("timestamp", DateTime.UtcNow.ToString("o"))
                ).ToString();
            }
        </trace>
    </outbound>
    <on-error />
</policies>
