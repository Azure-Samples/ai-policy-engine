                    @{ return $"CACHE LOOKUP key={context.Variables["cacheKey"]} bypass={(bool)context.Variables["bypassCache"]} hit={context.Variables.ContainsKey("cachedResponseBody") && context.Variables["cachedResponseBody"] != null}"; }
                </trace>
